# risk of Y based on number of treatments ---------------------------------------

# oud
(true_means <- do.call(rbind, lapply(0:8, function(n_treatments) {
  treated <- data |> filter(rowSums(data[, ..A]) == n_treatments)
  mean_Y1 <- mean(treated$oud_period_4)
  data.frame(
    n_treatments = n_treatments,
    mean_Y1 = mean_Y1,
    stringsAsFactors = FALSE
  )
})))

