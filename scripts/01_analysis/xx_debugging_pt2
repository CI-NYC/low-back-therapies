# calculate true mean for Y among uncensored participants, for each treatment individually

library(tidyverse)
library(data.table)
library(glue)

source("~/medicaid/low-back-therapies/R/helpers.R")

data <- load_data("pain_cohort_clean_imputed.fst", file.path(drv_root, "final")) |> as.data.table()
version <- "mlr3superlearner"

A <- (c("exposure_acetaminophen",
        # "exposure_acupuncture",
        "exposure_anti_inflammatory",
        "exposure_benzodiazepine",
        "exposure_chiropractic",
        "exposure_duloxetine",
        "exposure_gabapentin",
        "exposure_intervention",
        "exposure_muscle_relaxant",
        "exposure_massage_therapy",
        "exposure_physical_therapy",
        "exposure_steroid",
        "exposure_opioid"
        # "exposure_max_daily_dose_mme",
        # "exposure_days_supply"
))

# filter to those who remain uncensored for entire study period
data <- data |> filter(cens_period_4 == 1)

# outcome OUD (results appear fine)
(true_means <- do.call(rbind, lapply(A, function(treatment) {
  treated <- data |> filter(!!sym(treatment) == 1)
  mean_Y1 <- mean(treated$oud_period_4)
  treated <- data |> filter(!!sym(treatment) == 0)
  mean_Y0 <- mean(treated$oud_period_4)
  data.frame(
    treatment = treatment,
    mean_Y1 = mean_Y1,
    mean_Y0 = mean_Y0,
    risk_difference = mean_Y1 - mean_Y0,
    stringsAsFactors = FALSE
  )
})))

mean(true_means$risk_difference)

